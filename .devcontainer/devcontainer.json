{
  // 🔹 コンテナ名（任意）
  "name": "base-devcontainer",

  // 🔹 ベースイメージ（必要に応じて変更）
  // "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  // "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",


  // 🔹 便利ツール群をまとめて入れる公式feature
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {}
  },

  "mounts": [
    // ✅ Windowsは USERPROFILE を使うのが安定
    // 例: C:\Users\yourname\.claude
    "source=${localEnv:USERPROFILE}/.claude,target=/home/vscode/.claude,type=bind"
  ],

  // 🔹 コンテナ初回作成時に実行するスクリプト
  "postCreateCommand": "sed -i 's/\\r$//' .devcontainer/post-create.sh && chmod +x .devcontainer/post-create.sh && bash .devcontainer/post-create.sh",

  // 🔹 VS Code 側の設定
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}